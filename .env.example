# ============================================
# SocialBrain AI — Environment Variables
# ============================================
# Copy file này thành .env rồi điền giá trị thật:
#   copy .env.example .env
#
# ⚠️ KHÔNG BAO GIỜ commit file .env lên GitHub!
# File .env đã được thêm vào .gitignore.
# ============================================

# --- App Settings ---
APP_NAME=SocialBrain AI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- LLM Providers (Phase 1) ---
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Lấy key tại: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# --- Ollama (Phase 6) ---
# OLLAMA_BASE_URL=http://localhost:11434
